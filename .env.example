# Xserver 登录凭据（必填）
XSERVER_MEMBER_ID=你的会员ID
XSERVER_PASSWORD=你的密码

# 验证码识别 API（可选，有默认值）
# CAPTCHA_API=https://captcha-120546510085.asia-northeast1.run.app

# Chrome CDP 地址（容器内自动管理，一般无需修改）
# CDP_URL=http://127.0.0.1:9222

# cf-clearance-scraper 服务地址（docker-compose 自动配置，一般无需修改）
# CF_SOLVER_URL=http://cf-solver:3000/cf-clearance-scraper

# Telegram 通知（可选，留空则不发送通知）
# 从 @BotFather 获取 Bot Token，从 @userinfobot 获取 Chat ID
# TG_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# TG_CHAT_ID=123456789

# 定时模式 - cron 表达式，容器将持续运行并按计划执行
# 默认每天东京时间 08:00（UTC 23:00）
CRON_SCHEDULE=0 23 * * *

# 时区（默认 Asia/Tokyo）
# TZ=Asia/Tokyo
