# Xserver VPS 续期 - 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ============================================================
# 必填配置
# ============================================================

# Xserver 会员 ID（必填）
XSERVER_MEMBER_ID=

# Xserver 密码（必填）
XSERVER_PASSWORD=

# ============================================================
# 验证码识别（Keras API）
# ============================================================

# Keras 模型 API（Cloud Run 部署，必须配置）
# 格式: POST 请求，body = 原始 base64 图片，response = 纯文本 6 位验证码
# 必填：填入你的 Cloud Run 端点地址
CAPTCHA_API=

# ============================================================
# 可选配置 - Turnstile API 求解
# ============================================================

# CapSolver API 密钥（推荐，优先使用，用于 Turnstile 验证）
# 注册地址: https://www.capsolver.com/
# 费用: ~$0.0015/次
# CAPSOLVER_API_KEY=

# 2Captcha API 密钥（备选，用于 Turnstile 验证）
# 注册地址: https://2captcha.com/
# 费用: ~$0.002/次
# 注意: 此 Key 仅用于 Turnstile 求解，不再用于图形验证码识别
# TWOCAPTCHA_API_KEY=

# ============================================================
# 可选配置 - 代理
# ============================================================

# 代理类型（可选）: http / socks4 / socks5
# PROXY_TYPE=http

# 代理地址（可选）
# PROXY_ADDRESS=your-proxy-ip

# 代理端口（可选）
# PROXY_PORT=8080

# 代理用户名（可选）
# PROXY_LOGIN=

# 代理密码（可选）
# PROXY_PASSWORD=

# ============================================================
# 可选配置 - Telegram 通知
# ============================================================

# Telegram Bot Token（可选）
# 获取方式: 与 @BotFather 对话创建 Bot
# TG_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Telegram Chat ID（可选）
# 获取方式: 与 @userinfobot 对话
# TG_CHAT_ID=123456789

# ============================================================
# 可选配置 - Chrome 路径（本地运行）
# ============================================================

# Chrome 可执行文件路径（可选，默认自动检测）
# macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux: /usr/bin/google-chrome-stable
# CHROME_PATH=

# Chrome 用户数据目录（可选，默认 /data/chrome-profile）
# CHROME_USER_DATA=

# ============================================================
# 可选配置 - 定时调度（Docker 部署）
# ============================================================

# Cron 表达式（可选，默认未启用定时任务）
# ⚠️ 重要：cron 使用容器本地时间（由 TZ 环境变量控制）
#
# 格式: 分 时 日 月 周
# 示例：
#   CRON_SCHEDULE=0 8 * * *   → 每天东京时间 08:00（UTC 23:00 前一天，北京时间 07:00）
#   CRON_SCHEDULE=0 23 * * *  → 每天东京时间 23:00（UTC 14:00，北京时间 22:00）
#
# 推荐时间（避免高峰）：
#   - 东京时间 08:00（早上）或 23:00（晚上）
# CRON_SCHEDULE=0 23 * * *

# 时区（可选，默认 Asia/Tokyo）
# 此时区同时影响：
#   1. cron 定时任务的执行时间
#   2. 日志中的时间戳显示
#   3. VPS 到期日期判断（东京时区）
# TZ=Asia/Tokyo

# ============================================================
# 可选配置 - 高级设置
# ============================================================

# 启用容器环境诊断（可选，设为 true 时启动时运行 diagnostics.sh）
# ENABLE_DIAGNOSTICS=true

# 续期记录持久化文件路径（可选，默认 /data/renewal-status.json）
# RENEWAL_STATUS_FILE=/data/renewal-status.json

# 连续失败达到此次值时触发告警升级（可选，默认 3）
# ALERT_AFTER_FAILURES=3
