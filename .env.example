# Xserver VPS 续期 - 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ============================================================
# 必填配置
# ============================================================

# Xserver 会员 ID（必填）
XSERVER_MEMBER_ID=

# Xserver 密码（必填）
XSERVER_PASSWORD=

# ============================================================
# 验证码识别
# ============================================================

# 2Captcha API 密钥（必填，用于图形验证码人工识别）
# 注册地址: https://2captcha.com/
# 费用: ~$0.003/次 (~0.02元人民币/次)
# TWOCAPTCHA_API_KEY=

# ============================================================
# 可选配置 - Turnstile API 求解
# ============================================================

# CapSolver API 密钥（可选，优先使用，用于 Turnstile 验证）
# 注册地址: https://www.capsolver.com/
# CAPSOLVER_API_KEY=

# ============================================================
# 可选配置 - 代理
# ============================================================

# 代理类型（可选）: http / socks4 / socks5
# PROXY_TYPE=http

# 代理地址（可选）
# PROXY_ADDRESS=your-proxy-ip

# 代理端口（可选）
# PROXY_PORT=8080

# 代理用户名（可选）
# PROXY_LOGIN=

# 代理密码（可选）
# PROXY_PASSWORD=

# ============================================================
# 可选配置 - Telegram 通知
# ============================================================

# Telegram Bot Token（可选）
# 获取方式: 与 @BotFather 对话创建 Bot
# TG_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Telegram Chat ID（可选）
# 获取方式: 与 @userinfobot 对话
# TG_CHAT_ID=123456789

# ============================================================
# 可选配置 - Chrome 路径（本地运行）
# ============================================================

# Chrome 可执行文件路径（可选，默认自动检测）
# macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux: /usr/bin/google-chrome-stable
# CHROME_PATH=

# Chrome 用户数据目录（可选，默认 /data/chrome-profile）
# CHROME_USER_DATA=

# ============================================================
# 可选配置 - 定时调度（Docker 部署）
# ============================================================

# Cron 表达式（可选，默认每天 UTC 23:00 即东京时间 08:00）
# 格式: 分 时 日 月 周
# 示例: 0 3 * * * （每天 UTC 03:00 即东京时间 12:00）
# CRON_SCHEDULE=0 23 * * *

# 时区（可选，默认 Asia/Tokyo）
# TZ=Asia/Tokyo
